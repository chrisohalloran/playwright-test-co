{
  "name": "playwright-test-co",
  "version": "0.1.0",
  "description": "Run only the Playwright tests affected by your PR changes",
  "type": "module",
  "bin": {
    "playwright-test-co": "src/cli.js",
    "ptc": "src/cli.js"
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "ptc": "node src/cli.js",
    "demo": "node src/cli.js --project sample-project --files sample-project/src/components/login-form.js"
  },
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "targeted",
    "ci",
    "diff",
    "pr"
  ],
  "author": "Chris O'Halloran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisohalloran/playwright-test-co.git"
  },
  "homepage": "https://chrisohalloran.github.io/playwright-test-co/",
  "engines": {
    "node": ">=18"
  }
}
