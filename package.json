{
  "name": "playwright-test-co",
  "version": "0.1.0",
  "description": "Run only the Playwright tests affected by your PR changes",
  "type": "module",
  "bin": {
    "ptc": "./src/cli.js"
  },
  "scripts": {
    "ptc": "node src/cli.js",
    "demo": "node src/cli.js --project sample-project --files sample-project/src/components/login-form.js"
  },
  "keywords": ["playwright", "testing", "e2e", "targeted", "ci"],
  "license": "MIT"
}
